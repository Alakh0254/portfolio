# ==========================================
# POSTGRESQL CONFIGURATION (MANDATORY)
# ==========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Note: If you just installed PostgreSQL, the default password is often what you set during installation.
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/portfolio_db

# Other App Configs
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173
SECRET_KEY=super-secret-key-for-jwt-change-in-production
